SET(CMAKE_SYSTEM_NAME Windows)

SET(USE_64BITS OFF)
IF(USE_64BITS)
  SET(CROSSCOMPILER x86_64-w64-mingw32-)
  SET(SYSROOT /usr/local/Cellar/mingw-w64/5.0.4_1/toolchain-x86_64/mingw)
ELSE()
  SET(CROSSCOMPILER i686-w64-mingw32-)
  SET(SYSROOT /usr/local/Cellar/mingw-w64/5.0.4_1/toolchain-i686/mingw)
ENDIF()
SET(HOST_COMPILER gcc -m32)
IF($ENV{CROSSCOMPILER})
  SET(CROSSCOMPILER $ENV{CROSSCOMPILER})
ENDIF()
IF($ENV{SYSROOT})
  SET(SYSROOT $ENV{SYSROOT})
ENDIF()
SET(Windows ON)
SET(WIN32 ON)
SET(CMAKE_C_COMPILER   ${CROSSCOMPILER}gcc)
SET(CMAKE_CXX_COMPILER ${CROSSCOMPILER}g++)
SET(CMAKE_RC_COMPILER  ${CROSSCOMPILER}windres)
SET(CMAKE_C_FLAGS "-I${SYSROOT}/include")

SET(CMAKE_FIND_ROOT_PATH ${SYSROOT})
SET(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
SET(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
SET(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)

